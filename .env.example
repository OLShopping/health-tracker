# ============================================================
# health-tracker 环境变量配置
# 复制此文件为 .env，然后填入实际值
# ============================================================

# GitHub Personal Access Token（公开仓库可留空，私有仓库必填）
GITHUB_TOKEN=

# 要构建的 GitHub 分支（默认为 main）
BRANCH=main

# Flask 密钥（生产环境请改为复杂随机字符串）
SECRET_KEY=change-me-in-production
